# Local Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://bgreen:bgreen_dev@localhost:5432/bgreen

# Public URL of the web app (used to build invite accept URLs).
APP_PUBLIC_URL=http://localhost:3000

# Outbound mail (V2.3+). Defaults point at the local Mailpit container —
# emails caught at http://localhost:8025. Swap to a real SMTP relay in prod.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=bGreen <invites@bgreen.local>
# SMTP_USER=
# SMTP_PASS=

# AI (V6+)
ANTHROPIC_API_KEY=

# Auth (V2+)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Central Services (V5.4). On boot, if the user with this email exists,
# they're promoted to central_services / admin. New users with the same
# email are also classified as CS admin on first WorkOS sync.
GLOBAL_ADMIN_EMAIL=

# Background jobs (V6+)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Storage (V6+)
AWS_REGION=eu-central-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Observability (later)
POSTHOG_API_KEY=
