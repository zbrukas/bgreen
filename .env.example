# Local Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://bgreen:bgreen_dev@localhost:5432/bgreen

# Public URL of the org-facing web app (used to build invite accept URLs
# and to bounce mis-routed CS users back here).
APP_PUBLIC_URL=http://localhost:3000
# Public URL of the central-services console (V5.4). The org app sends
# CS users here on sign-in; the CS app sends org users back to APP_PUBLIC_URL.
CS_APP_PUBLIC_URL=http://localhost:3001

# Outbound mail (V2.3+). Defaults point at the local Mailpit container —
# emails caught at http://localhost:8025. Swap to a real SMTP relay in prod.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=bGreen <invites@bgreen.local>
# SMTP_USER=
# SMTP_PASS=

# AI (V6+)
ANTHROPIC_API_KEY=

# Auth (V2+)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Central Services (V5.4 + V5.7). On boot, the user with this email is
# created (or promoted) as a central_services admin. With V5.7 the CS
# console authenticates locally — first sign-in by this email triggers a
# password-setup flow; no WorkOS account is needed for CS users.
GLOBAL_ADMIN_EMAIL=

# HMAC secret for CS session tokens (apps/cs). Must be at least 32 chars.
# Rotate to invalidate every CS session. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
CS_SESSION_SECRET=

# Background jobs (V6+)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Storage (V6+). Defaults below point at the local MinIO container —
# console at http://localhost:9001 (user: bgreen / pw: bgreen_dev).
# In prod, leave S3_ENDPOINT unset to use real AWS S3 in the named region.
AWS_REGION=eu-central-1
S3_BUCKET=bgreen-dev
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=bgreen
S3_SECRET_ACCESS_KEY=bgreen_dev

# Observability (later)
POSTHOG_API_KEY=
