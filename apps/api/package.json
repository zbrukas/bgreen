    "seed-framework-datapoints": "tsx scripts/seed-framework-datapoints.ts"
  },
  "dependencies": {
    "@bgreen/ai": "workspace:*",
    "@bgreen/auth": "workspace:*",
    "@bgreen/cs-telemetry": "workspace:*",
    "@bgreen/db": "workspace:*",
    "@bgreen/emails": "workspace:*",
    "@bgreen/form-engine": "workspace:*",
    "@bgreen/frameworks": "workspace:*",
    "@bgreen/pdf-engine": "workspace:*",
    "@bgreen/pt-data": "workspace:*",
    "@bgreen/scoring": "workspace:*",
    "@bgreen/storage": "workspace:*",
    "@bgreen/types": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@workos-inc/node": "^7.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "inngest": "^3.27.4",
    "posthog-node": "^4.4.1",
    "xstate": "^5.31.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
