{
  "name": "@bgreen/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./rpc": "./src/rpc.ts"
  },
  "scripts": {
    "dev": "tsx watch --ignore data/ src/index.ts",
